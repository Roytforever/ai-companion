# 大模型 API 配置
# 支持 OpenAI、DeepSeek、通义千问、Kimi、OpenRouter、Ollama 等（UI 侧用 provider 下拉切换）
# 默认提供商（留空则 cloud→deepseek / local→ollama）；可选 deepseek/openai/qwen/moonshot/openrouter/ollama/custom
LLM_PROVIDER=
# 模型提供商插件目录（Hermes 式 plugins/ 扩展点）：把 <name>.py 丢进去即注册新提供商，
# 模块导出 `PROVIDER_SPEC = ProviderSpec(...)` 或定义 `register(registry)`。默认项目根/provider_plugins
PROVIDER_PLUGINS_DIR=
LLM_API_KEY=your-api-key-here
LLM_BASE_URL=https://api.deepseek.com/v1
LLM_MODEL=deepseek-chat

# 各 provider 的 key（按 UI 所选提供商读取对应环境变量；未设置则回退 LLM_API_KEY）
OPENAI_API_KEY=
DASHSCOPE_API_KEY=
MOONSHOT_API_KEY=
OPENROUTER_API_KEY=

# 模型后端：cloud（云端兼容接口）| local（本地 Ollama 等）
LLM_BACKEND=cloud
# 请求超时（秒）
LLM_TIMEOUT=60
# 本地模型（provider=ollama 或 LLM_BACKEND=local 时生效）
LOCAL_MODEL_BASE_URL=http://localhost:11434/v1
LOCAL_MODEL_NAME=llama3

# 视觉/多模态（Phase 4）
# 主模型是否支持视觉：留空=按模型名自动推断；true/false=强制
SUPPORTS_VISION=
# 辅助视觉模型：主模型无视觉能力时，用于把图片转成文字描述（需为视觉模型）
AUX_VISION_MODEL=

# MCP 服务器（Phase 4）：JSON 字符串，stdio 用 command/args/env，http 用 url/headers
# 示例（文件系统 MCP，需先 npm i -g @modelcontextprotocol/server-filesystem）：
# MCP_SERVERS={"filesystem":{"command":"npx","args":["-y","@modelcontextprotocol/server-filesystem","/tmp"],"enabled":true}}
# Phase 5 增强：HTTP 服务器支持 OAuth（auth）+ mTLS（client_cert/client_key/ssl_verify）+ 工具过滤
# 示例（OAuth client_credentials）：
# MCP_SERVERS={"myapi":{"url":"https://mcp.example.com/mcp","auth":{"type":"oauth","grant":"client_credentials","token_url":"https://auth.example.com/token","client_id":"x","client_secret":"y","scope":"mcp"},"enabled":true}}
# 示例（mTLS）：
# MCP_SERVERS={"internal":{"url":"https://mcp.internal/mcp","client_cert":"~/secrets/client.pem","client_key":"~/secrets/client.key","ssl_verify":"~/secrets/ca.pem","enabled":true}}
# 示例（工具过滤：仅注册 create_issue/list_issues）：
# MCP_SERVERS={"github":{"command":"npx","args":["-y","@modelcontextprotocol/server-github"],"env":{"GITHUB_PERSONAL_ACCESS_TOKEN":"***"},"tools":{"include":["create_issue","list_issues"]},"enabled":true}}
MCP_SERVERS=
# 文件读取允许的根目录（Phase 4，分号分隔），默认仅项目根
FILE_READ_ROOTS=
# MCP OAuth 令牌缓存目录（Phase 5，默认项目根/.mcp_tokens）
MCP_TOKEN_DIR=

# Skills Hub 来源（Phase 5）：JSON 列表
# 形如 [{"type":"local","path":"/abs/path"},{"type":"github","repo":"owner/repo","ref":"main","subdir":"skills"},{"type":"url","url":"https://.../index.json"}]
# ref 快捷方式：local:<name> / url:<http> / github:<owner/repo>/<path>
SKILLS_HUB_SOURCES=
# Hermes 主目录（Phase 5）：SOUL.md 等全局身份仅从此加载，默认 ~/.hermes
HERMES_HOME=
# RL 轨迹 / 导出数据目录（Phase 5，默认项目根/data/rl）
RL_DATA_DIR=

# 可选：记忆系统配置
MEMORY_STORE=local    # local | json

# ============ P0：权限 / 执行 / 压缩 / 推理 ============
# 工具权限模式：ask(默认，危险工具需授权) / allow(全部放行) / deny(全部拒绝)
TOOL_PERMISSION_MODE=ask
# 是否启用权限系统（false 则等同 allow）
TOOL_PERMISSIONS_ENABLED=true
# shell 执行命令白名单（逗号分隔），留空用内置默认安全清单
# 示例：SHELL_ALLOWLIST=git,python,pip,ls,cat,echo,node,npm
SHELL_ALLOWLIST=
# 上下文压缩阈值（估算 token），超阈值时旧轮次被摘要；0 表示关闭
CONTEXT_COMPACT_THRESHOLD=6000
# 推理/思考模式透传：true 时把 reasoning 参数转发给支持的模型（o1/o3/深度推理本地模型）
REASONING_ENABLED=false
# 推理强度（low/medium/high），或配合 REASONING_EXTRA_BODY 自定义
REASONING_EFFORT=medium
# 自定义 reasoning extra_body（JSON 字符串），优先级高于默认；不同后端语义不同
# 示例：REASONING_EXTRA_BODY={"reasoning_effort":"high"}
REASONING_EXTRA_BODY=

# ============ P1：子智能体 + 定时调度 ============
# 子智能体最大递归深度（防止 token 爆炸 / 无限委派）
SUBAGENT_MAX_DEPTH=3
# 单个子智能体最大工具循环轮数
SUBAGENT_MAX_ITER=4
# MoA 默认并行「参考顾问」数量（同模型多视角模式下生效）
MOA_DEFAULT_REFERENCES=2
# MoA 真实多模型池：顾问模型列表（"provider:model" 逗号分隔）。
# 例: deepseek:deepseek-chat, qwen:qwen-plus, openai:gpt-4o-mini
# 留空则回退「同模型多视角」模式（仅 prompt 视角不同）。
MOA_ADVISOR_MODELS=
# MoA 聚合者模型（"provider:model"）。留空用主模型（保留完整工具能力）；
# 指定则单轮综合。
MOA_AGGREGATOR=
# 调度器是否启用后台 tick 线程（false 则仅能手动 run_now）
SCHEDULER_ENABLED=true
# 调度器 tick 周期（秒），对齐 Hermes 默认 60
SCHEDULER_TICK_SECONDS=60
# 调度器数据目录（jobs.json/inbox.json/output/，默认项目根/data/schedules）
SCHEDULER_DATA_DIR=

# ============ P1b：hooks / 斜杠命令 / 浏览器 / 辩证用户建模 ============
# 事件钩子是否启用（.hooks/hooks.json）
HOOKS_ENABLED=true
# 钩子配置目录（默认项目根/.hooks）
HOOKS_DIR=
# 钩子 Python 插件目录（.hooks/plugins/*.py，默认 HOOKS_DIR/plugins）
HOOKS_PLUGINS_DIR=
# 斜杠命令目录（commands/<name>.md，默认项目根/commands）
SLASH_COMMANDS_DIR=
# bundle 自动激活的 context 目录（install_bundle 把 context/*.md 复制到这里，默认项目根/context）
BUNDLE_CONTEXT_DIR=
# 浏览器后端：auto(默认，自动探测 Playwright) / playwright(真实浏览器) / fetch(纯网页读取)
BROWSER_BACKEND=auto
# 浏览器抓取超时（秒）
BROWSER_TIMEOUT=30
# 浏览器截图保存目录（默认项目根/screenshots）
BROWSER_SCREENSHOT_DIR=

# 项目设置
APP_NAME=AI-Companion
APP_LANG=zh-CN